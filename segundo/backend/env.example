# Copy this file to backend/.env before running docker compose:
#   cp backend/env.example backend/.env
# Values below use docker-compose service hostnames (mysql, redis).
# For local runs outside Docker, switch hosts to localhost.

# App
APP_NAME=AI Analytics Chatbot
CORS_ORIGINS=["http://localhost:5173"]

# MySQL (not consumed by code yet — wired in when the SQL tool lands)
DATABASE_URL=mysql+pymysql://analytics:analytics@mysql:3306/analytics

# Redis conversational memory
REDIS_URL=redis://redis:6379/0
# 14 days — sessions must survive the ~1-week review window
CONVERSATION_TTL_SECONDS=1209600

# LLM provider (generic and swappable — OpenCode GO models sit behind this)
LLM_PROVIDER=opencode
LLM_API_BASE=https://api.example.com/v1
LLM_API_KEY=changeme
LLM_MODEL=qwen3-coder
