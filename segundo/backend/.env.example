# Copy this file to backend/.env before running docker compose or uvicorn:
#   cp backend/env.example backend/.env
# Then set LLM_API_KEY below to your real OpenCode GO key.
#
# DATABASE_URL / REDIS_URL host note:
#   - docker-compose (api service): use the values below as-is (mysql/redis
#     are the compose service names, resolved on the compose network).
#   - local dev (uvicorn run directly, infra still via `docker compose up`):
#     swap the host to localhost, e.g.
#     mysql+pymysql://analytics:analytics@localhost:3306/analytics
#   - production (VPS): point at your real MySQL/Redis hosts, credentials,
#     and TLS settings — do not reuse the analytics/analytics dev password.

# App
APP_NAME=AI Analytics Chatbot
# Comma-separated origins the frontend is served from. Add your production
# domain here before deploying (e.g. ["https://your-app.example.com"]).
CORS_ORIGINS=["http://localhost:5173"]

# MySQL — see host note above.
DATABASE_URL=mysql+pymysql://analytics:analytics@mysql:3306/analytics

# Redis — conversational memory, per conversation_id. See host note above.
REDIS_URL=redis://redis:6379/0
# 14 days — sessions must survive the ~1-week evaluation review window.
CONVERSATION_TTL_SECONDS=1209600

# LLM — OpenAI-compatible endpoint. OpenCode GO is the provider this backend
# is built against; get LLM_API_KEY from your OpenCode GO account.
# Required for the LLM tool-calling agent — without it, the backend still
# runs and answers via the deterministic planner fallback (no key needed).
LLM_PROVIDER=openai-compatible
LLM_API_BASE=https://opencode.ai/zen/go/v1
LLM_API_KEY=your-opencode-go-key-here
# Default model; switchable per-request from the UI's model selector
# (20 models allow-listed in backend/app/agent/models.py). deepseek-v4-pro
# is the most reliable at completing tool calls rather than just narrating.
LLM_MODEL=deepseek-v4-pro
