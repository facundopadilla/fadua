# Production environment for the AI Analytics Chatbot.
# Copy this file to `.env` (in this same segundo/ directory) and fill in the
# placeholders below, then run:
#   docker compose -f docker-compose.prod.yml up -d --build
#
# This file is read by the `api` service (env_file) in docker-compose.prod.yml.
# Do NOT commit the real .env with secrets.

APP_NAME=AI Analytics Chatbot

# --- Database (EXTERNAL production MySQL — NOT a container) -----------------
# Point this at your managed/external MySQL. Load the seed once with:
#   mysql -h YOUR_PROD_MYSQL_HOST -u USER -p DBNAME < db/init.sql
DATABASE_URL=mysql+pymysql://USER:PASSWORD@YOUR_PROD_MYSQL_HOST:3306/DBNAME

# --- Redis (the `redis` service in docker-compose.prod.yml) ----------------
# Leave as-is to use the bundled Redis container. To use an external/managed
# Redis instead, replace with redis://USER:PASSWORD@HOST:6379/0.
REDIS_URL=redis://redis:6379/0

# Conversation retention in Redis. 1209600 = 14 days.
CONVERSATION_TTL_SECONDS=1209600

# --- LLM provider (OpenCode GO, OpenAI-compatible) -------------------------
LLM_PROVIDER=openai-compatible
LLM_API_BASE=https://opencode.ai/zen/go/v1
LLM_MODEL=deepseek-v4-pro
# Get this from your OpenCode GO account. Without it, the backend falls back to
# the deterministic (no-LLM) planner.
LLM_API_KEY=your-opencode-go-key-here

# --- CORS ------------------------------------------------------------------
# NOT needed when the SPA is served same-origin through the nginx /api proxy
# (the default in docker-compose.prod.yml). Only relevant if you serve the
# frontend from a DIFFERENT origin than the API. Must be a JSON array of
# strings (pydantic parses it as a list), e.g.:
#   CORS_ORIGINS=["https://app.yourdomain.com"]
CORS_ORIGINS=["https://your-domain.example"]
