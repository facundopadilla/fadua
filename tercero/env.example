# Google Sheets document ID (public gviz CSV export, read-only).
# Default matches the FADUA challenge sheet; override for clone testing.
SHEET_ID=1y6aREOjFrbDd5bKlpt72UBc6svk_pr2wBsAqv_xb_2Y

# Directory for JSONL results log + evidence screenshots.
RUNS_DIR=runs

# AI provider abstraction (OpenCode GO — Qwen, Minimax, GLM, ...).
# Used ONLY as a fallback for column->field mapping when a required
# field is left unmapped by the deterministic matcher. The LLM never
# sees row values (PII) — only column headers and field labels.
OPENCODE_BASE_URL=https://api.opencode.example.com/v1
OPENCODE_API_KEY=
OPENCODE_MODEL=qwen-2.5-72b-instruct
